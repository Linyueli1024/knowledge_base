{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MemoraNote",
  "version": "0.1.1",
  "identifier": "com.linyu.knowledge-base",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MemoraNote",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyREZBOTg2QjVDMkRBNgpSV1NtTFZ4cm1Qb3REYXdCZWZ4NWFSQ1RreS9BNWVtMlVJYTRBSjZaSGhLT1BoU2c1QlNlZGNFcgo=",
      "active": true,
      "endpoints": [
        "https://github.com/Linyueli1024/knowledge_base/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
